#!/usr/bin/env elixir 

Mix.install([{:pro_gen, path: "."}])

alias ProGen.Script, as: PG

PG.cli_args(
  name: "greet",
  description: "A simple greeting script",
  version: "0.1.0",
  options: [
    name: [
      short: "-n",
      long: "--name",
      help: "Name to greet",
      required: true
    ]
  ],
  flags: [
    loud: [
      short: "-l",
      long: "--loud",
      help: "Greet loudly"
    ]
  ]
)

PG.parse_args()

PG.puts "HELLO WORLD"
