# install_claude
# install_tidewave_mcp 
# claude mcp add --transport stdio tidewave mcp-proxy http://localhost:4000/tidewave/mcp --scope project
# # mix igniter.install claude --yes
# EOF

# run_cmd "Generate LLM plans"  "fab_plans -a $PROJECT"
# run_cmd "Add usage_rules"     "mix igniter.install usage_rules --only dev --yes"
# run_cmd "Generate RULES.md"   "echo 0 | mix usage_rules.sync RULES.md --link-to-folder RULES --all"
run_cmd "Add mix completions" "mix complete.bash > /dev/null"

run_block "Segregate base modules" << EOF
echo $(pwd)
cd lib
mkdir ${PROJECT}_base 
mv ${PROJECT}/application.ex ${PROJECT}_base
mv ${PROJECT}/mailer.ex      ${PROJECT}_base
mv ${PROJECT}/repo.ex        ${PROJECT}_base
mv ${PROJECT}/secrets.ex     ${PROJECT}_base
EOF

msg "DONE ${PROJECT}"
